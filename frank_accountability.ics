BEGIN:VEVENT
UID:frank-urge-pause@independence-plan
DTSTAMP:20260704T120000Z
DTSTART;TZID=America/New_York:20260704T120000
DTEND;TZID=America/New_York:20260704T121000
RRULE:FREQ=DAILY
SUMMARY:Before texting her — WAIT 30 min
DESCRIPTION:Urge to text/call her?\n\n1. Do NOT send yet\n2. Write it in Notes first\n3. Wait 30 minutes\n4. Re-read it. Still need to send?\n\nStatements only. No extraction questions.
BEGIN:VALARM
TRIGGER:-PT0M
ACTION:DISPLAY
DESCRIPTION:Pause before contacting her
END:VALARM
END:VEVENT
